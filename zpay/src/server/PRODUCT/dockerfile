# Stage 1: Build the zingo-cli binary using Rust with zingolib version 1.10.3
FROM rust:1.79 as builder

# Install build dependencies (including unzip to extract the zip archive)
RUN apt-get update && apt-get install -y \
    build-essential \
    libssl-dev \
    protobuf-compiler \
    unzip \
    curl

# Set the working directory and download the specific version of zingolib (v1.10.3)
WORKDIR /app
RUN curl -L -o zingolib.zip https://github.com/zingolabs/zingolib/archive/refs/tags/1.10.3.zip && \
    unzip zingolib.zip

# Change into the unzipped directory (the folder name is based on the archive; adjust if needed)
WORKDIR /app/zingolib-1.10.3

# Build the CLI in release mode for the package zingo-cli
RUN cargo build --release --package zingo-cli

# Stage 2: Create a minimal runtime image with OpenSSL 3, bc, jq, and curl
FROM debian:bookworm-slim

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    bc \
    jq \
    curl && \
    rm -rf /var/lib/apt/lists/*

# Copy the zingo-cli binary from the builder stage
COPY --from=builder /app/zingolib-1.10.3/target/release/zingo-cli /usr/local/bin/zingo-cli

# Copy the startup script (make sure you have a 'run.sh' in your build context)
WORKDIR /app
COPY run.sh /app/run.sh
RUN chmod +x /app/run.sh

# Create a shared folder (mountable from the host)
VOLUME ["/shared"]

# Set the working directory for wallet data (can be mounted if desired)
WORKDIR /data

# Use tini as init to handle signals properly
RUN apt-get update && apt-get install -y tini && rm -rf /var/lib/apt/lists/*
ENTRYPOINT ["/usr/bin/tini", "--"]

# Run the startup script
CMD ["/app/run.sh"]

