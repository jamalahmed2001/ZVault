# Stage 1: Build the zingo-cli binary using Rust with zingolib v3.0.0 (NU6 support)
FROM rust:1.90 AS builder

RUN apt-get update && apt-get install -y \
    build-essential \
    libssl-dev \
    protobuf-compiler \
    unzip \
    curl

WORKDIR /app
RUN curl -L -o zingolib.zip https://github.com/zingolabs/zingolib/archive/refs/tags/zingolib_v3.0.0.zip && \
    unzip zingolib.zip

WORKDIR /app/zingolib-zingolib_v3.0.0

RUN cargo build --release --package zingo-cli

# Stage 2: Runtime - use Ubuntu 24.04 for glibc 2.38+ (required by rust:1.90-built binary)
FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    libsqlite3-0 \
    bc \
    jq \
    curl && \
    rm -rf /var/lib/apt/lists/*

# Copy the zingo-cli binary from the builder stage
COPY --from=builder /app/zingolib-zingolib_v3.0.0/target/release/zingo-cli /usr/local/bin/zingo-cli

# Copy the startup script (make sure you have a 'run.sh' in your build context)
WORKDIR /app
COPY run.sh /app/run.sh
RUN chmod +x /app/run.sh

# Create a shared folder (mountable from the host)
VOLUME ["/shared"]

# Set the working directory for wallet data (can be mounted if desired)
WORKDIR /data

# Use tini as init to handle signals properly
RUN apt-get update && apt-get install -y tini && rm -rf /var/lib/apt/lists/*
ENTRYPOINT ["/usr/bin/tini", "--"]

# Run the startup script
CMD ["/app/run.sh"]

